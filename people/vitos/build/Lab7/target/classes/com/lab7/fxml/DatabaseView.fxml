<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lab7.controllers.DatabaseController">
    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <HBox spacing="10.0">
                <Button onAction="#handleGetVersion" text="Версия БД" />
                <Button onAction="#handleRefreshData" text="Обновить данные" />
                <Button onAction="#handleCreateDemoTable" text="Создать таблицы, справочники и учет операций" />
                <Button onAction="#handleClose" text="Закрыть" />
            </HBox>
            <Label text="Результат запроса SELECT VERSION():" />
            <TextArea fx:id="versionArea" editable="false" prefHeight="70.0" />
            <Label fx:id="summaryLabel" text="Сводка БД" />
            <Label text="Данные из таблицы пользователей (проект VSC_Vitos):" />
            <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="55.0" text="ID" />
                    <TableColumn fx:id="usernameColumn" prefWidth="210.0" text="Пользователь" />
                    <TableColumn fx:id="riskColumn" prefWidth="140.0" text="Риск-профиль" />
                    <TableColumn fx:id="balanceColumn" prefWidth="130.0" text="Баланс" />
                    <TableColumn fx:id="openOrdersColumn" prefWidth="120.0" text="Открытые заявки" />
                    <TableColumn fx:id="activeColumn" prefWidth="90.0" text="Активен" />
                    <TableColumn fx:id="createdAtColumn" prefWidth="170.0" text="Дата создания" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
