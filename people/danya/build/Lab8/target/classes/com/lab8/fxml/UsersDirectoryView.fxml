<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lab8.controllers.UsersDirectoryController">
    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <HBox spacing="10.0">
                <Button onAction="#handleRefresh" text="Обновить" />
                <Button onAction="#handleClose" text="Закрыть" />
            </HBox>
            <TableView fx:id="usersTable" columnResizePolicy="CONSTRAINED_RESIZE_POLICY" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" />
                    <TableColumn fx:id="emailColumn" text="Email" />
                    <TableColumn fx:id="roleColumn" text="Role" />
                    <TableColumn fx:id="planColumn" text="Plan" />
                    <TableColumn fx:id="analysesColumn" text="Analyses" />
                    <TableColumn fx:id="activeColumn" text="Active" />
                    <TableColumn fx:id="createdAtColumn" text="Created At" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>

